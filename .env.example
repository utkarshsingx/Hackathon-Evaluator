# AI API Keys (server-side only - never exposed to client)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Drive folder access: use service account for shared folders (API key returns empty)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Fallback if no service account (only works for public folders)
GOOGLE_DRIVE_API_KEY=

# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for admin delete (bypasses RLS). Find in Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=

# Optional: For share links (defaults to Vercel URL or localhost)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
